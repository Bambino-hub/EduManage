{# Formulaire de changement de mot de passe, partagé par les layouts admin et enseignant
   (cf. templates/security/change_password.html.twig, qui extend l'un ou l'autre selon le rôle). #}
<div class="row">
    <div class="col-lg-5">
        <div class="admin-card">
            <div class="admin-card-body">
                {{ form_start(form) }}
                    <div class="mb-3" data-controller="password-toggle">
                        {{ form_label(form.currentPassword) }}
                        <div class="input-group">
                            {{ form_widget(form.currentPassword, {attr: {'data-password-toggle-target': 'input'}}) }}
                            <button type="button" class="btn btn-outline-secondary" data-action="password-toggle#toggle"
                                    aria-label="Afficher ou masquer le mot de passe">
                                <i class="bi bi-eye-slash" data-password-toggle-target="icon"></i>
                            </button>
                        </div>
                        {{ form_errors(form.currentPassword) }}
                    </div>

                    <div class="mb-3" data-controller="password-toggle">
                        {{ form_label(form.plainPassword.first) }}
                        <div class="input-group">
                            {{ form_widget(form.plainPassword.first, {attr: {'data-password-toggle-target': 'input'}}) }}
                            <button type="button" class="btn btn-outline-secondary" data-action="password-toggle#toggle"
                                    aria-label="Afficher ou masquer le mot de passe">
                                <i class="bi bi-eye-slash" data-password-toggle-target="icon"></i>
                            </button>
                        </div>
                        {{ form_errors(form.plainPassword.first) }}
                    </div>

                    <div class="mb-3" data-controller="password-toggle">
                        {{ form_label(form.plainPassword.second) }}
                        <div class="input-group">
                            {{ form_widget(form.plainPassword.second, {attr: {'data-password-toggle-target': 'input'}}) }}
                            <button type="button" class="btn btn-outline-secondary" data-action="password-toggle#toggle"
                                    aria-label="Afficher ou masquer le mot de passe">
                                <i class="bi bi-eye-slash" data-password-toggle-target="icon"></i>
                            </button>
                        </div>
                        {{ form_errors(form.plainPassword.second) }}
                    </div>

                    <button type="submit" class="btn btn-primary">Changer le mot de passe</button>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
