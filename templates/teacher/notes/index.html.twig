{% extends 'teacher/layout.html.twig' %}

{% block title %}Mes notes — EduManage{% endblock %}
{% block page_title %}Mes notes{% endblock %}

{% block content %}
{% if not trimestre %}
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle-fill me-1"></i>
        Aucun trimestre actif pour l'instant — demandez à l'administration d'en activer un avant de saisir des notes.
    </div>
{% else %}
    <p class="text-muted mb-3">Trimestre en cours : <strong>{{ trimestre.libelle }}</strong> ({{ trimestre.anneeScolaire.libelle }})</p>
{% endif %}

<div class="admin-card">
    <div class="admin-card-header">
        <h2 class="admin-card-title">
            <i class="bi bi-journal-check me-2 text-college-purple"></i>Mes classes et matières
        </h2>
    </div>
    <div class="admin-card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 table-stack">
                <thead class="table-light">
                    <tr>
                        <th>CLASSE</th>
                        <th>MATIÈRE</th>
                        <th class="text-end">ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    {% for attribution in attributions %}
                        <tr>
                            <td class="fw-semibold td-title">{{ attribution.classe.nom }}</td>
                            <td data-label="Matière">{{ attribution.matiere.nom }}</td>
                            <td class="text-end">
                                <a href="{{ path('teacher_notes_attribution', {id: attribution.id}) }}" class="btn btn-sm btn-primary">
                                    <i class="bi bi-pencil-square me-1"></i>Saisir les notes
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="3" class="text-center text-muted py-5">
                                <i class="bi bi-inbox fs-3 d-block mb-2 opacity-50"></i>
                                Aucune attribution trouvée pour l'année en cours.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
