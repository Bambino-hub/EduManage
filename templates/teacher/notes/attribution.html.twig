{% extends 'teacher/layout.html.twig' %}

{% block title %}{{ attribution.classe.nom }} — {{ attribution.matiere.nom }} — EduManage{% endblock %}
{% block page_title %}{{ attribution.classe.nom }} — {{ attribution.matiere.nom }}{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <p class="text-muted mb-0">{{ trimestre.libelle }}</p>
    <div class="d-flex gap-2">
        <a href="{{ path('teacher_notes_fiche', {id: attribution.id}) }}" class="btn btn-primary btn-sm">
            <i class="bi bi-grid-3x3 me-1"></i>Remplir la fiche de notes
        </a>
        <a href="{{ path('teacher_notes_index') }}" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Retour
        </a>
    </div>
</div>
{% endblock %}
