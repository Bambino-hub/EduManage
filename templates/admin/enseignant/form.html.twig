{% extends 'admin/layout.html.twig' %}

{% block title %}{{ enseignant.id ? 'Modifier' : 'Ajouter' }} un enseignant — EduManage{% endblock %}
{% block page_title %}{{ enseignant.id ? 'Modifier' : 'Ajouter' }} un enseignant{% endblock %}

{% block admin_content %}
<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="admin-card">
            <div class="admin-card-header">
                <h2 class="admin-card-title">
                    <i class="bi bi-person-badge-fill me-2 text-college-purple"></i>
                    {{ enseignant.id ? enseignant.nomComplet : 'Nouvel enseignant' }}
                </h2>
                <a href="{{ path('admin_enseignant_index') }}" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Retour
                </a>
            </div>
            <div class="admin-card-body">
                {{ form_start(form) }}
                {{ form_errors(form) }}
                <div class="row g-3">
                    <div class="col-5">{{ form_row(form.nom) }}</div>
                    <div class="col-5">{{ form_row(form.prenom) }}</div>
                    <div class="col-2">{{ form_row(form.sexe) }}</div>
                    <div class="col-7">{{ form_row(form.email) }}</div>
                    <div class="col-5">{{ form_row(form.telephone) }}</div>
                    <div class="col-6">{{ form_row(form.type) }}</div>
                    <div class="col-6">{{ form_row(form.poste) }}</div>
                    <div class="col-6">{{ form_row(form.matricule) }}</div>
                    <div class="col-6">{{ form_row(form.specialite) }}</div>
                    <div class="col-6">{{ form_row(form.cycle) }}</div>
                    <div class="col-12">{{ form_row(form.actif) }}</div>
                </div>
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Enregistrer
                    </button>
                    <a href="{{ path('admin_enseignant_index') }}" class="btn btn-outline-secondary">Annuler</a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
