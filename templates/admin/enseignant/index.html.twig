{% extends 'admin/layout.html.twig' %}
{% import 'admin/macros.html.twig' as ui %}

{% block title %}Enseignants — EduManage{% endblock %}
{% block page_title %}Enseignants{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h4 mb-0">Enseignants</h1>
    <a href="{{ path('admin_enseignant_new') }}" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>Ajouter un enseignant
    </a>
</div>

<div class="admin-card">
    <div class="admin-card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nom complet</th>
                    <th>Email</th>
                    <th>Téléphone</th>
                    <th>Statut</th>
                    <th>Actif</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for e in enseignants %}
                <tr>
                    <td>
                        <div class="fw-semibold">{{ e.nomComplet }}</div>
                        {% if e.specialite %}
                            <small class="text-muted">{{ e.specialite }}</small>
                        {% endif %}
                    </td>
                    <td class="text-muted small">{{ e.email }}</td>
                    <td class="text-muted small">{{ e.telephone ?? '—' }}</td>
                    <td><span class="badge bg-secondary">{{ e.type.label() }}</span></td>
                    <td>
                        {% if e.actif %}
                            <i class="bi bi-check-circle-fill text-success"></i>
                        {% else %}
                            <i class="bi bi-x-circle text-muted"></i>
                        {% endif %}
                    </td>
                    <td>
                        {{ ui.actions(
                            path('admin_enseignant_edit', {id: e.id}),
                            path('admin_enseignant_delete', {id: e.id}),
                            e.id,
                            'Supprimer ' ~ e.nomComplet ~ ' ?'
                        ) }}
                    </td>
                </tr>
                {% else %}
                    {{ ui.empty_row(6, 'Aucun enseignant enregistré.') }}
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
