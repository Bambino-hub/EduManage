{% extends 'admin/layout.html.twig' %}

{% block title %}Modifier un élève — EduManage{% endblock %}
{% block page_title %}Modifier un élève{% endblock %}

{% block admin_content %}
<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="admin-card">
            <div class="admin-card-header">
                <h2 class="admin-card-title">
                    <i class="bi bi-mortarboard-fill me-2 text-college-purple"></i>
                    {{ eleve.nomComplet }}
                    <span class="text-muted small fw-normal">— Matricule {{ eleve.matricule }}</span>
                </h2>
                <a href="{{ path('admin_eleve_index') }}" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Retour
                </a>
            </div>
            <div class="admin-card-body">
                {{ form_start(form) }}
                {{ form_errors(form) }}
                <div class="row g-3">
                    <div class="col-6">{{ form_row(form.nom) }}</div>
                    <div class="col-6">{{ form_row(form.prenom) }}</div>
                    <div class="col-12">
                        {% if eleve.photo %}
                            <img src="{{ asset('uploads/eleves/' ~ eleve.photo) }}" alt="" class="rounded mb-2" style="height:100px;width:80px;object-fit:cover;border:1px solid #ccc">
                        {% endif %}
                        {{ form_row(form.photo) }}
                    </div>
                    <div class="col-3">{{ form_row(form.sexe) }}</div>
                    <div class="col-4">{{ form_row(form.dateNaissance) }}</div>
                    <div class="col-5">{{ form_row(form.lieuNaissance) }}</div>
                    <div class="col-12">{{ form_row(form.adresse) }}</div>
                    <div class="col-12"><hr class="my-2"></div>
                    <div class="col-6">{{ form_row(form.nomTuteur) }}</div>
                    <div class="col-6">{{ form_row(form.lienTuteur) }}</div>
                    <div class="col-6">{{ form_row(form.telephoneTuteur) }}</div>
                    <div class="col-6">{{ form_row(form.emailTuteur) }}</div>
                    <div class="col-6">{{ form_row(form.statut) }}</div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Enregistrer
                    </button>
                    <a href="{{ path('admin_eleve_index') }}" class="btn btn-outline-secondary">Annuler</a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
