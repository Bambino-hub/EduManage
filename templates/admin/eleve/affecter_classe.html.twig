{% extends 'admin/layout.html.twig' %}

{% block title %}Affecter une classe — EduManage{% endblock %}
{% block page_title %}Affecter une classe{% endblock %}

{% block admin_content %}
<div class="row justify-content-center">
    <div class="col-lg-5">
        <div class="admin-card">
            <div class="admin-card-header">
                <h2 class="admin-card-title">
                    <i class="bi bi-signpost-split-fill me-2 text-college-purple"></i>
                    {{ inscription.eleve.nomComplet }} — {{ inscription.niveau.nomComplet }}
                </h2>
                <a href="{{ path('admin_eleve_show', {id: inscription.eleve.id}) }}" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Retour
                </a>
            </div>
            <div class="admin-card-body">
                {{ form_start(form) }}
                {{ form_errors(form) }}
                {{ form_row(form.classe) }}

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Affecter
                    </button>
                    <a href="{{ path('admin_eleve_show', {id: inscription.eleve.id}) }}" class="btn btn-outline-secondary">Annuler</a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
