{% extends 'admin/layout.html.twig' %}

{% block title %}Clôturer une inscription — EduManage{% endblock %}
{% block page_title %}Clôturer une inscription{% endblock %}

{% block admin_content %}
<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="admin-card">
            <div class="admin-card-header">
                <h2 class="admin-card-title">
                    <i class="bi bi-box-arrow-right me-2 text-college-purple"></i>
                    {{ inscription.eleve.nomComplet }} — {{ inscription.classe ? inscription.classe.nom : inscription.niveau.nomComplet ~ ' (en attente de classe)' }}
                </h2>
                <a href="{{ path('admin_eleve_show', {id: inscription.eleve.id}) }}" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Retour
                </a>
            </div>
            <div class="admin-card-body">
                {{ form_start(form) }}
                {{ form_errors(form) }}
                <div class="row g-3">
                    <div class="col-6">{{ form_row(form.dateFin) }}</div>
                    <div class="col-6">{{ form_row(form.motifFin) }}</div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-check-lg me-1"></i>Clôturer l'inscription
                    </button>
                    <a href="{{ path('admin_eleve_show', {id: inscription.eleve.id}) }}" class="btn btn-outline-secondary">Annuler</a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
