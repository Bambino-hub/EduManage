{% extends 'admin/layout.html.twig' %}

{% block title %}Inscrire {{ eleve.nomComplet }} — EduManage{% endblock %}
{% block page_title %}Inscrire un élève{% endblock %}

{% block admin_content %}
<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="admin-card">
            <div class="admin-card-header">
                <h2 class="admin-card-title">
                    <i class="bi bi-journal-bookmark-fill me-2 text-college-purple"></i>
                    Inscrire {{ eleve.nomComplet }}
                </h2>
                <a href="{{ path('admin_eleve_show', {id: eleve.id}) }}" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Retour
                </a>
            </div>
            <div class="admin-card-body">
                {{ form_start(form) }}
                {{ form_errors(form) }}
                <div class="row g-3">
                    <div class="col-12">{{ form_row(form.niveau) }}</div>
                    <div class="col-6">{{ form_row(form.dateInscription) }}</div>
                    <div class="col-6">{{ form_row(form.redoublant) }}</div>
                </div>
                <p class="text-muted small mt-2 mb-0">
                    <i class="bi bi-info-circle me-1"></i>La classe s'affecte ensuite, depuis la fiche élève ou l'écran d'affectation en lot.
                </p>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Inscrire
                    </button>
                    <a href="{{ path('admin_eleve_show', {id: eleve.id}) }}" class="btn btn-outline-secondary">Annuler</a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
