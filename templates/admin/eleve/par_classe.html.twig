{% extends 'admin/layout.html.twig' %}

{% block title %}{{ classe ? 'Élèves de ' ~ classe.nom : 'Élèves par classe' }} — EduManage{% endblock %}
{% block page_title %}Élèves par classe{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4 no-print" data-controller="entete-toggle">
    <div>
        <h1 class="h4 mb-1">Élèves par classe</h1>
        {% if classe %}
            <p class="text-muted mb-0" style="font-size:.85rem">
                {{ classe.niveau.nomComplet }} — {{ classe.nom }} — {{ inscriptions|length }} élève{{ inscriptions|length > 1 ? 's' : '' }}
            </p>
        {% endif %}
    </div>
    <div class="d-flex align-items-center gap-2">
        {% if classe %}
            <div class="form-check form-switch mb-0">
                <input class="form-check-input" type="checkbox" role="switch" id="toggleEnteteEleves"
                       data-entete-toggle-target="checkbox" data-action="entete-toggle#update">
                <label class="form-check-label small" for="toggleEnteteEleves">En-tête</label>
            </div>
            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="window.print()">
                <i class="bi bi-printer-fill me-1"></i>Imprimer
            </button>
            <a href="{{ path('admin_eleve_export_word', {classe: classe.id}) }}" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-file-earmark-word-fill me-1"></i>Word
            </a>
            <a href="{{ path('admin_eleve_export_pdf', {classe: classe.id}) }}"
               data-base-href="{{ path('admin_eleve_export_pdf', {classe: classe.id}) }}"
               data-entete-toggle-target="link"
               class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-file-earmark-pdf-fill me-1"></i>PDF
            </a>
        {% endif %}
        <a href="{{ path('admin_eleve_index') }}" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Retour aux élèves
        </a>
    </div>
</div>

<div class="admin-card mb-3 no-print">
    <div class="admin-card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-6">
                <label class="form-label small fw-semibold">Classe</label>
                <select name="classe" class="form-select form-select-sm" onchange="this.form.submit()">
                    <option value="">— Choisir une classe —</option>
                    {% for c in classes %}
                        <option value="{{ c.id }}" {{ classe and classe.id == c.id ? 'selected' }}>
                            {{ c.niveau.nomComplet }} — {{ c.nom }}
                        </option>
                    {% else %}
                        <option value="">Aucune classe active cette année</option>
                    {% endfor %}
                </select>
            </div>
        </form>
    </div>
</div>

{% if classe %}
    <h1 class="h4 mb-1 d-none d-print-block">{{ classe.niveau.nomComplet }} — {{ classe.nom }}</h1>
    <p class="text-muted mb-4 d-none d-print-block" style="font-size:.85rem">{{ inscriptions|length }} élève{{ inscriptions|length > 1 ? 's' : '' }}</p>

    <div class="admin-card">
        <div class="admin-card-body p-0">
            <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 table-stack">
                <thead class="table-light">
                    <tr>
                        <th style="width:50px">N°</th>
                        <th>MATRICULE</th>
                        <th>NOM ET PRÉNOMS</th>
                        <th>SEXE</th>
                        <th>REDOUBLANT</th>
                        <th class="text-end no-print">ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    {% for inscription in inscriptions %}
                        {% set e = inscription.eleve %}
                        <tr>
                            <td class="text-muted small">{{ loop.index }}</td>
                            <td class="text-muted small" data-label="Matricule">{{ e.matricule }}</td>
                            <td class="fw-semibold td-title">{{ e.nomComplet }}</td>
                            <td class="text-muted small" data-label="Sexe">{{ e.sexe ? e.sexe.value : '—' }}</td>
                            <td data-label="Redoublant">
                                {% if inscription.redoublant %}<span class="badge bg-warning text-dark">Oui</span>{% else %}—{% endif %}
                            </td>
                            <td class="text-end no-print">
                                <a href="{{ path('admin_eleve_show', {id: e.id}) }}" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center text-muted py-5">
                                <i class="bi bi-inbox fs-3 d-block mb-2 opacity-50"></i>
                                Aucun élève inscrit dans cette classe.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
            </div>
        </div>
    </div>
{% else %}
    <div class="admin-card">
        <div class="admin-card-body text-center text-muted py-5">
            <i class="bi bi-people display-6 d-block mb-2"></i>
            Choisissez une classe pour afficher la liste de ses élèves.
        </div>
    </div>
{% endif %}
{% endblock %}
