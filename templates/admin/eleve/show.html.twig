{% extends 'admin/layout.html.twig' %}

{% block title %}{{ eleve.nomComplet }} — EduManage{% endblock %}
{% block page_title %}Fiche élève{% endblock %}

{% block admin_content %}
{% set inscriptionEnCours = eleve.inscriptionEnCours %}
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div class="d-flex align-items-center gap-3">
        {% if eleve.photo %}
            <img src="{{ asset('uploads/eleves/' ~ eleve.photo) }}" alt="" class="rounded" style="height:70px;width:56px;object-fit:cover;border:1px solid #ccc">
        {% endif %}
        <div>
            <h1 class="h4 mb-1">{{ eleve.nomComplet }}</h1>
            <p class="text-muted mb-0 small">Matricule {{ eleve.matricule }}{% if inscriptionEnCours %} — {{ inscriptionEnCours.classe ? inscriptionEnCours.classe.nom : inscriptionEnCours.niveau.nomComplet ~ ' (en attente de classe)' }}{% endif %}</p>
        </div>
    </div>
    <div class="d-flex gap-2">
        <a href="{{ path('admin_eleve_edit', {id: eleve.id}) }}" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-pencil me-1"></i>Modifier
        </a>
        <a href="{{ path('admin_eleve_index') }}" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Retour
        </a>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-5">
        <div class="admin-card">
            <div class="admin-card-header">
                <h2 class="admin-card-title">
                    <i class="bi bi-person-vcard-fill me-2 text-college-purple"></i>Informations
                </h2>
            </div>
            <div class="admin-card-body">
                <dl class="row mb-0">
                    <dt class="col-5 text-muted small">Nom et prénoms</dt>
                    <dd class="col-7">{{ eleve.nomComplet }}</dd>

                    <dt class="col-5 text-muted small">Sexe</dt>
                    <dd class="col-7">{{ eleve.sexe ? eleve.sexe.value : '—' }}</dd>

                    <dt class="col-5 text-muted small">Date de naissance</dt>
                    <dd class="col-7">{{ eleve.dateNaissance ? eleve.dateNaissance|date('d/m/Y') : '—' }}{{ eleve.lieuNaissance ? ' à ' ~ eleve.lieuNaissance : '' }}</dd>

                    <dt class="col-5 text-muted small">Adresse</dt>
                    <dd class="col-7">{{ eleve.adresse ?? '—' }}</dd>

                    <dt class="col-5 text-muted small">Statut</dt>
                    <dd class="col-7"><span class="badge bg-secondary">{{ eleve.statut.label() }}</span></dd>
                </dl>
            </div>
        </div>

        <div class="admin-card mt-3">
            <div class="admin-card-header">
                <h2 class="admin-card-title">
                    <i class="bi bi-people-fill me-2 text-college-purple"></i>Parent / Tuteur
                </h2>
            </div>
            <div class="admin-card-body">
                <dl class="row mb-0">
                    <dt class="col-5 text-muted small">Nom</dt>
                    <dd class="col-7">{{ eleve.nomTuteur }}</dd>

                    <dt class="col-5 text-muted small">Lien</dt>
                    <dd class="col-7">{{ eleve.lienTuteur ?? '—' }}</dd>

                    <dt class="col-5 text-muted small">Téléphone</dt>
                    <dd class="col-7">{{ eleve.telephoneTuteur }}</dd>

                    <dt class="col-5 text-muted small">E-mail</dt>
                    <dd class="col-7">{{ eleve.emailTuteur ?? '—' }}</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="admin-card">
            <div class="admin-card-header">
                <h2 class="admin-card-title">
                    <i class="bi bi-journal-bookmark-fill me-2 text-college-purple"></i>Scolarité
                </h2>
                {% if not inscriptionEnCours %}
                    <a href="{{ path('admin_inscription_new', {id: eleve.id}) }}" class="btn btn-primary btn-sm">
                        <i class="bi bi-plus-lg me-1"></i>Inscrire
                    </a>
                {% elseif not inscriptionEnCours.classe %}
                    <a href="{{ path('admin_inscription_affecter_classe', {id: inscriptionEnCours.id}) }}" class="btn btn-primary btn-sm">
                        <i class="bi bi-signpost-split-fill me-1"></i>Affecter une classe
                    </a>
                {% endif %}
            </div>
            <div class="admin-card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 table-stack">
                        <thead class="table-light">
                            <tr>
                                <th>CLASSE</th>
                                <th>DÉBUT</th>
                                <th>FIN</th>
                                <th>MOTIF</th>
                                <th>REDOUBLANT</th>
                                <th class="text-end">ACTIONS</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for inscription in eleve.inscriptions %}
                                <tr>
                                    <td class="td-title fw-semibold">
                                        {% if inscription.classe %}
                                            {{ inscription.classe.nom }}
                                        {% else %}
                                            <span class="text-muted small fst-italic">{{ inscription.niveau.nomComplet }} — en attente de classe</span>
                                        {% endif %}
                                    </td>
                                    <td class="small" data-label="Début">{{ inscription.dateInscription|date('d/m/Y') }}</td>
                                    <td class="small" data-label="Fin">{{ inscription.dateFin ? inscription.dateFin|date('d/m/Y') : '—' }}</td>
                                    <td class="small" data-label="Motif">{{ inscription.motifFin ? inscription.motifFin.label() : '—' }}</td>
                                    <td data-label="Redoublant">
                                        {% if inscription.redoublant %}<span class="badge bg-warning text-dark">Oui</span>{% else %}—{% endif %}
                                    </td>
                                    <td class="text-end">
                                        {% if inscription.enCours %}
                                            <a href="{{ path('admin_inscription_cloturer', {id: inscription.id}) }}" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-box-arrow-right me-1"></i>Clôturer
                                            </a>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-5">
                                        <i class="bi bi-inbox fs-3 d-block mb-2 opacity-50"></i>
                                        Aucune inscription enregistrée.
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
