{% extends 'admin/layout.html.twig' %}

{% block title %}{{ creneau.id ? 'Modifier' : 'Nouveau' }} créneau — EduManage{% endblock %}
{% block page_title %}{{ creneau.id ? 'Modifier' : 'Nouveau' }} créneau horaire{% endblock %}

{% block admin_content %}
<div class="row justify-content-center">
    <div class="col-lg-5">
        <div class="admin-card">
            <div class="admin-card-header">
                <h2 class="admin-card-title">
                    <i class="bi bi-clock-fill me-2 text-college-purple"></i>
                    {{ creneau.id ? creneau.label : 'Nouveau créneau' }}
                </h2>
                <a href="{{ path('admin_creneau_index') }}" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Retour
                </a>
            </div>
            <div class="admin-card-body">
                {{ form_start(form) }}
                {{ form_errors(form) }}
                <div class="row g-3">
                    <div class="col-12">{{ form_row(form.jourSemaine) }}</div>
                    <div class="col-6">{{ form_row(form.heureDebut) }}</div>
                    <div class="col-6">{{ form_row(form.heureFin) }}</div>
                    <div class="col-12">{{ form_row(form.ordre) }}</div>
                </div>
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Enregistrer
                    </button>
                    <a href="{{ path('admin_creneau_index') }}" class="btn btn-outline-secondary">Annuler</a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
