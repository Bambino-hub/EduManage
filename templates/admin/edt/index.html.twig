{% extends 'admin/layout.html.twig' %}

{% block title %}Emplois du temps — EduManage{% endblock %}
{% block page_title %}Emplois du temps{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4 no-print">
    <div>
        <h1 class="h4 mb-1">Emplois du temps</h1>
        <p class="text-muted mb-0" style="font-size:.85rem">Vue en lecture seule, par classe ou par enseignant.</p>
    </div>
    <div class="d-flex gap-2">
        {% if classeSelectionnee or enseignantSelectionne %}
            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="window.print()">
                <i class="bi bi-printer-fill me-1"></i>Imprimer
            </button>
            <a href="{{ path('admin_edt_export_pdf', classeSelectionnee ? {classe: classeSelectionnee} : {enseignant: enseignantSelectionne}) }}"
               class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-file-earmark-pdf-fill me-1"></i>Exporter PDF
            </a>
        {% endif %}
        <div class="dropdown">
            <button type="button" class="btn btn-outline-secondary btn-sm dropdown-toggle" data-bs-toggle="dropdown">
                <i class="bi bi-printer me-1"></i>Imprimer en masse
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" href="{{ path('admin_edt_imprimer_classes') }}">Toutes les classes — aperçu</a></li>
                <li><a class="dropdown-item" href="{{ path('admin_edt_imprimer_classes_export_pdf') }}">Toutes les classes — PDF</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item" href="{{ path('admin_edt_imprimer_enseignants') }}">Tous les enseignants — aperçu</a></li>
                <li><a class="dropdown-item" href="{{ path('admin_edt_imprimer_enseignants_export_pdf') }}">Tous les enseignants — PDF</a></li>
            </ul>
        </div>
        <a href="{{ path('admin_edt_globale') }}" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-grid-3x3-gap-fill me-1"></i>Vue globale
        </a>
        <a href="{{ path('admin_edt_generate') }}" class="btn btn-sm" style="background:var(--college-orange);color:#fff">
            <i class="bi bi-lightning-charge-fill me-1"></i>Génération auto
        </a>
    </div>
</div>

{% if classeObj or enseignantObj %}
    <h1 class="h4 mb-4 d-none d-print-block">
        Emploi du temps — {{ classeObj ? classeObj.nom ~ ' — ' ~ classeObj.anneeScolaire.libelle : enseignantObj.nomComplet }}
    </h1>
{% endif %}

<div class="admin-card mb-4 no-print">
    <div class="admin-card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-5">
                <form method="get">
                    <label class="form-label small fw-semibold">Par classe</label>
                    <select name="classe" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="">— Choisir une classe —</option>
                        {% for classe in classes %}
                            <option value="{{ classe.id }}" {{ classeSelectionnee == classe.id ? 'selected' }}>
                                {{ classe.nom }} — {{ classe.anneeScolaire.libelle }}
                            </option>
                        {% endfor %}
                    </select>
                </form>
            </div>
            <div class="col-md-1 text-center text-muted small">ou</div>
            <div class="col-md-5">
                <form method="get">
                    <label class="form-label small fw-semibold">Par enseignant</label>
                    <select name="enseignant" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="">— Choisir un enseignant —</option>
                        {% for enseignant in enseignants %}
                            <option value="{{ enseignant.id }}" {{ enseignantSelectionne == enseignant.id ? 'selected' }}>
                                {{ enseignant.nomComplet }}
                            </option>
                        {% endfor %}
                    </select>
                </form>
            </div>
        </div>
    </div>
</div>

{% if not classeSelectionnee and not enseignantSelectionne %}
    <div class="admin-card">
        <div class="admin-card-body text-center text-muted py-5">
            <i class="bi bi-calendar-week display-6 d-block mb-2"></i>
            Choisissez une classe ou un enseignant pour afficher son emploi du temps.
        </div>
    </div>
{% else %}
    <div class="admin-card">
        <div class="admin-card-body p-0" style="overflow-x:auto">
            {% include 'admin/edt/_grille_semaine.html.twig' with {
                joursAffiches: joursAffiches,
                ordreMax: ordreMax,
                creneauxParJour: creneauxParJour,
                grille: grille,
                contexte: enseignantSelectionne ? 'enseignant' : 'classe',
            } only %}
        </div>
    </div>
{% endif %}
{% endblock %}
