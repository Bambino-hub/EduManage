{% extends 'admin/layout.html.twig' %}

{% block title %}Imprimer — tous les enseignants — EduManage{% endblock %}
{% block page_title %}Imprimer — tous les enseignants{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4 no-print" data-controller="entete-toggle">
    <div>
        <h1 class="h4 mb-1">Imprimer — tous les enseignants</h1>
        <p class="text-muted mb-0" style="font-size:.85rem">
            Un enseignant par page{{ annee ? ' — ' ~ annee.libelle : '' }} (seuls ceux ayant au moins une heure
            placée cette année sont listés). "Exporter PDF" est recommandé : rendu identique quel que soit le
            navigateur. Le bouton Imprimer ouvre la boîte de dialogue du navigateur, dont la pagination peut
            varier selon le navigateur utilisé (Firefox notamment).
        </p>
    </div>
    <div class="d-flex align-items-center gap-2">
        <div class="form-check form-switch mb-0">
            <input class="form-check-input" type="checkbox" role="switch" id="toggleEnteteEdtEnseignants"
                   data-entete-toggle-target="checkbox" data-action="entete-toggle#update">
            <label class="form-check-label small" for="toggleEnteteEdtEnseignants">En-tête du collège</label>
        </div>
        <a href="{{ path('admin_edt_imprimer_enseignants_export_pdf') }}"
           data-base-href="{{ path('admin_edt_imprimer_enseignants_export_pdf') }}"
           data-entete-toggle-target="link"
           class="btn btn-sm" style="background:var(--college-orange);color:#fff">
            <i class="bi bi-file-earmark-pdf-fill me-1"></i>Exporter PDF
        </a>
        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="window.print()">
            <i class="bi bi-printer-fill me-1"></i>Imprimer
        </button>
        <a href="{{ path('admin_edt_index') }}" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Retour
        </a>
    </div>
</div>

{% if enseignants is empty %}
    <div class="admin-card">
        <div class="admin-card-body text-center text-muted py-5">
            <i class="bi bi-calendar-week display-6 d-block mb-2"></i>
            Aucun enseignant avec une heure placée cette année.
        </div>
    </div>
{% else %}
    {% for enseignant in enseignants %}
        <div class="edt-print-page">
            <h1 class="h4 mb-3">
                Emploi du temps — {{ enseignant.nomComplet }}{{ annee ? ' — ' ~ annee.libelle : '' }}
            </h1>
            <div class="admin-card mb-4">
                <div class="admin-card-body p-0" style="overflow-x:auto">
                    {% include 'admin/edt/_grille_semaine.html.twig' with {
                        joursAffiches: joursAffiches,
                        ordreMax: ordreMax,
                        creneauxParJour: creneauxParJour,
                        grille: grillesParEnseignant[enseignant.id] ?? [],
                        contexte: 'enseignant',
                    } only %}
                </div>
            </div>
        </div>
    {% endfor %}
{% endif %}
{% endblock %}
