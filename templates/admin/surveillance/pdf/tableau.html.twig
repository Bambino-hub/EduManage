<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="utf-8">
<style>
    @page { margin: 1cm; }
    body { font-family: 'DejaVu Sans', sans-serif; color: #1a1a2e; }
    h1 { font-size: 15px; margin: 0 0 2px; text-align: center; text-transform: uppercase; }
    .sous-titre { color: #555; font-size: 10px; margin: 0 0 12px; text-align: center; }
    table { width: 100%; border-collapse: collapse; font-size: 7.5px; table-layout: fixed; }
    th, td { border: 1px solid #333; padding: 3px; text-align: left; vertical-align: top; }
    th { background: #eef0f5; font-weight: bold; text-align: center; }
    td.jour { font-weight: bold; text-transform: uppercase; width: 65px; text-align: center; }
    td.heure { font-weight: bold; width: 50px; white-space: nowrap; text-align: center; }
    .matiere { font-weight: bold; }
    .assignation { margin: 1px 0; }
    .non-pourvu { color: #b45309; font-style: italic; }
</style>
</head>
<body>
    {% if avecEntete %}{% include 'admin/pdf/_entete_college.html.twig' %}{% endif %}
    <h1>Tableau de surveillance — {{ cycle.nom }}</h1>
    <p class="sous-titre">{{ entete ?: (annee ? 'Année scolaire ' ~ annee.libelle : '') }}</p>

    <table>
        <thead>
            <tr>
                <th style="width:65px">Jours</th>
                <th style="width:50px">Heures</th>
                {% for niveau in niveaux %}<th>{{ niveau.nomComplet }}</th>{% endfor %}
            </tr>
        </thead>
        <tbody>
            {% for ligne in lignes %}
                <tr>
                    <td class="jour">{{ ligne.jourSemaine ? ligne.jourSemaine.label()|upper : '' }} {{ ligne.date|date('d/m') }}</td>
                    <td class="heure">{{ ligne.heureDebut|date('H:i') }}-{{ ligne.heureFin|date('H:i') }}</td>
                    {% for niveau in niveaux %}
                        {% set examensNiveau = ligne.examensParNiveau[niveau.id] ?? [] %}
                        <td>
                            {% if examensNiveau is empty %}
                                —
                            {% else %}
                                {% for examen in examensNiveau %}
                                    <div class="matiere">{{ examen.matiere.code }}</div>
                                    {% for classe in classesParNiveau[niveau.id] ?? [] %}
                                        {% set surveillances = surveillancesParExamenClasse[examen.id][classe.id] ?? [] %}
                                        <div class="assignation">
                                            {{ classe.nom }}:
                                            {% if surveillances is empty %}
                                                <span class="non-pourvu">non pourvu</span>
                                            {% else %}
                                                {{ surveillances|map(s => s.enseignant.nom)|join(', ') }}
                                            {% endif %}
                                        </div>
                                    {% endfor %}
                                {% endfor %}
                            {% endif %}
                        </td>
                    {% endfor %}
                </tr>
            {% endfor %}
        </tbody>
    </table>
</body>
</html>
