{% extends 'admin/layout.html.twig' %}

{% block title %}Surveillance — EduManage{% endblock %}
{% block page_title %}Tableau de surveillance{% endblock %}

{% block admin_content %}
<h1 class="h4 mb-4">Tableau de surveillance</h1>

<div class="row g-4">
    {% for cycle in cycles %}
        <div class="col-md-6">
            <div class="admin-card h-100">
                <div class="admin-card-body d-flex flex-column">
                    <h2 class="h5 mb-1">
                        <i class="bi bi-shield-check me-2 text-college-purple"></i>{{ cycle.nom }}
                    </h2>
                    <p class="text-muted small mb-3">{{ cycle.type.label() }} — {{ cycle.niveaux|length }} niveau(x)</p>
                    <a href="{{ path('admin_surveillance_tableau', {cycle: cycle.id}) }}" class="btn btn-primary btn-sm mt-auto align-self-start">
                        <i class="bi bi-table me-1"></i>Voir le tableau de surveillance
                    </a>
                </div>
            </div>
        </div>
    {% else %}
        <div class="col-12">
            <div class="admin-card">
                <div class="admin-card-body text-center text-muted py-5">Aucun cycle configuré.</div>
            </div>
        </div>
    {% endfor %}
</div>
{% endblock %}
