{% extends 'admin/layout.html.twig' %}

{% block title %}Surveillance — {{ cycle.nom }} — EduManage{% endblock %}
{% block page_title %}Surveillance — {{ cycle.nom }}{% endblock %}

{% block admin_content %}
<style>
    .surveillance-program-table th, .surveillance-program-table td { border: 1px solid #dee2e6 !important; vertical-align: top; }
    .surveillance-program-table thead th { background: #f8f9fb; text-transform: uppercase; font-weight: 700; font-size: .78rem; text-align: center; }
    .surveillance-day { font-weight: 700; font-size: .82rem; text-transform: uppercase; white-space: nowrap; }
    .surveillance-slot { font-weight: 600; font-size: .82rem; white-space: nowrap; }
    .surveillance-entry { padding: .35rem; border: 1px solid #e4e7ec; border-radius: .3rem; margin-bottom: .35rem; }
    .surveillance-entry:last-child { margin-bottom: 0; }
    .surveillance-cell { margin-bottom: .15rem; font-size: .85rem; padding: .1rem .2rem; border-radius: .25rem; }
    .surveillance-cell.surv-drop-valid { outline: 2px dashed #6f42c1; outline-offset: 1px; background: #f5f0ff; cursor: pointer; }
    .surveillance-cell.surv-drop-swap { outline-style: solid; }
    .surveillance-item { cursor: grab; padding: .05rem .3rem; border-radius: .25rem; }
    .surveillance-item:hover { background: #eef0f3; }
    .surveillance-item.surv-selected { background: #6f42c1; color: #fff; }
    .surveillance-item.surv-dragging { opacity: .4; }
    .surveillance-item.surv-pending { background: #fff3cd; }
    .surveillance-item[draggable="false"] { cursor: not-allowed; opacity: .75; }
</style>

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h1 class="h4 mb-1">{{ entete ?: 'Tableau de surveillance — ' ~ cycle.nom }}</h1>
        <p class="text-muted mb-0 small">{{ annee ? 'Année scolaire ' ~ annee.libelle : 'Aucune année scolaire active' }}</p>
    </div>
</div>

<form method="get" class="card card-body mb-3 border-0 shadow-sm" style="background:#f8f9fb">
    <div class="row g-3 align-items-end">
        <div class="col-lg-9">
            <label class="form-label fw-semibold" for="entete">En-tête personnalisé</label>
            <input id="entete" name="entete" class="form-control" value="{{ entete }}" placeholder="Texte libre (optionnel)">
        </div>
        <div class="col-lg-3 d-grid">
            <button class="btn btn-dark" type="submit">Appliquer</button>
        </div>
    </div>
</form>

<div class="d-flex flex-wrap gap-2 mb-4">
    <a href="{{ path('admin_examen_tableau', {cycle: cycle.id, entete: entete}) }}" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Retour aux examens
    </a>
    <form method="post" action="{{ path('admin_surveillance_generate', {cycle: cycle.id}) }}"
          onsubmit="return confirm('Régénérer le tableau de surveillance des DEUX cycles (Collège + Lycée) ? Les affectations actuelles seront remplacées partout, pas seulement sur ce cycle.')">
        <input type="hidden" name="_token" value="{{ csrf_token('generer_surveillance') }}">
        <button type="submit" class="btn btn-outline-primary btn-sm" title="Régénère les deux cycles à la fois, pour garantir une répartition équitable des enseignants partagés entre collège et lycée">
            <i class="bi bi-lightning-charge-fill me-1"></i>Régénérer les surveillances (2 cycles)
        </button>
    </form>
    <a href="{{ path('admin_surveillance_export_pdf', {cycle: cycle.id, entete: entete}) }}" class="btn btn-primary btn-sm">
        <i class="bi bi-file-earmark-pdf-fill me-1"></i>Exporter le tableau en PDF
    </a>
</div>

<div class="admin-card"
     data-controller="surveillance-permutation"
     data-surveillance-permutation-save-url-value="{{ path('admin_surveillance_permuter') }}"
     data-surveillance-permutation-token-value="{{ csrf_token('permuter_surveillance') }}">
    <div class="admin-card-body">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <div class="text-center flex-grow-1">
                <h5 class="fw-bold mb-1">PROGRAMME DES SURVEILLANCES</h5>
                <div class="text-muted small">CYCLE : {{ cycle.nom|upper }}</div>
            </div>
        </div>

        <p class="text-muted small mb-2">
            <i class="bi bi-info-circle me-1"></i>Cliquez ou glissez le nom d'un surveillant vers une autre classe —
            <strong>même d'un autre examen</strong> — pour l'échanger ou combler un poste "non pourvu".
        </p>

        <div class="alert alert-danger d-none" data-surveillance-permutation-target="alert"></div>

        <div class="d-flex align-items-center gap-2 mb-3">
            <button type="button" class="btn btn-success btn-sm" disabled
                    data-surveillance-permutation-target="saveButton"
                    data-action="surveillance-permutation#enregistrer">
                <i class="bi bi-check-lg me-1"></i>Enregistrer les modifications
            </button>
            <button type="button" class="btn btn-outline-secondary btn-sm" disabled
                    data-surveillance-permutation-target="cancelButton"
                    data-action="surveillance-permutation#annuler">
                Annuler
            </button>
            <span class="text-muted small" data-surveillance-permutation-target="pendingCount"></span>
        </div>

        <div class="table-responsive">
            <table class="table surveillance-program-table align-middle mb-0">
                <thead>
                    <tr>
                        <th style="min-width:150px">Jours</th>
                        <th style="min-width:100px">Heures</th>
                        {% for niveau in niveaux %}
                            <th>{{ niveau.nomComplet }}</th>
                        {% endfor %}
                    </tr>
                </thead>
                <tbody>
                    {% for ligne in lignes %}
                        <tr>
                            <td class="surveillance-day">
                                {{ ligne.jourSemaine ? ligne.jourSemaine.label()|upper : '' }}<br>
                                {{ ligne.date|date('d/m/Y') }}
                            </td>
                            <td class="surveillance-slot">{{ ligne.heureDebut|date('H:i') }} - {{ ligne.heureFin|date('H:i') }}</td>
                            {% for niveau in niveaux %}
                                <td>
                                    {% set examensNiveau = ligne.examensParNiveau[niveau.id] ?? [] %}
                                    {% if examensNiveau is empty %}
                                        <span class="text-muted">-</span>
                                    {% else %}
                                        {% for examen in examensNiveau %}
                                            <div class="surveillance-entry">
                                                <div class="fw-semibold">{{ examen.matiere.code }}</div>
                                                {% for classe in classesParNiveau[niveau.id] ?? [] %}
                                                    {% set surveillances = surveillancesParExamenClasse[examen.id][classe.id] ?? [] %}
                                                    {% set fusionnee = groupeParClasseId[classe.id] is defined %}
                                                    <div class="surveillance-cell"
                                                         data-surveillance-permutation-target="cell"
                                                         data-examen-id="{{ examen.id }}"
                                                         data-classe-id="{{ classe.id }}"
                                                         data-fusion="{{ fusionnee ? '1' : '0' }}"
                                                         data-action="dragover->surveillance-permutation#dragOver drop->surveillance-permutation#drop click->surveillance-permutation#cellClick">
                                                        <span class="text-muted">{{ classe.nom }}:</span>
                                                        {% if surveillances is empty %}
                                                            <span class="text-warning surveillance-empty">non pourvu</span>
                                                        {% else %}
                                                            {% for surveillance in surveillances %}
                                                                <span class="surveillance-item"
                                                                      draggable="{{ fusionnee ? 'false' : 'true' }}"
                                                                      data-surveillance-permutation-target="item"
                                                                      data-surveillance-id="{{ surveillance.id }}"
                                                                      data-enseignant-id="{{ surveillance.enseignant.id }}"
                                                                      data-fusion="{{ fusionnee ? '1' : '0' }}"
                                                                      title="{{ fusionnee ? 'Classe réunie pour la surveillance : non déplaçable seule' : 'Glisser vers une autre classe, même d\'un autre examen' }}"
                                                                      data-action="dragstart->surveillance-permutation#dragStart dragend->surveillance-permutation#dragEnd click->surveillance-permutation#toggleSelect">{{ surveillance.enseignant.nom }}</span>{{ not loop.last ? ', ' : '' }}
                                                            {% endfor %}
                                                        {% endif %}
                                                    </div>
                                                {% endfor %}
                                            </div>
                                        {% endfor %}
                                    {% endif %}
                                </td>
                            {% endfor %}
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="{{ 2 + niveaux|length }}" class="text-center text-muted py-5">
                                Aucun examen programmé pour ce cycle.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
