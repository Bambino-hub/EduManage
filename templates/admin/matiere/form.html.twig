{% extends 'admin/layout.html.twig' %}

{% block title %}{{ matiere.id ? 'Modifier' : 'Nouvelle' }} matière — EduManage{% endblock %}
{% block page_title %}{{ matiere.id ? 'Modifier' : 'Nouvelle' }} matière{% endblock %}

{% block admin_content %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="admin-card">
            <div class="admin-card-header">
                <h2 class="admin-card-title">
                    <i class="bi bi-book-fill me-2 text-college-purple"></i>
                    {{ matiere.id ? 'Modifier ' ~ matiere.nom : 'Nouvelle matière' }}
                </h2>
                <a href="{{ path('admin_matiere_index') }}" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Retour
                </a>
            </div>
            <div class="admin-card-body">
                {{ form_start(form) }}
                {{ form_errors(form) }}

                <div class="row g-3 mb-4">
                    <div class="col-8">{{ form_row(form.nom) }}</div>
                    <div class="col-4">{{ form_row(form.code) }}</div>
                    <div class="col-4">{{ form_row(form.couleur) }}</div>
                    <div class="col-4">{{ form_row(form.groupeOptionnel) }}</div>
                    <div class="col-4">{{ form_row(form.salleRequise) }}</div>
                    <div class="col-4">{{ form_row(form.domaine) }}</div>
                </div>

                <h6 class="fw-semibold mb-3 border-bottom pb-2">
                    <i class="bi bi-sliders me-1 text-college-purple"></i>
                    Coefficients et volume horaire par niveau
                </h6>
                <table class="table table-sm align-middle mb-4">
                    <thead class="table-light">
                        <tr>
                            <th>Cycle</th>
                            <th>Niveau</th>
                            <th style="width:130px">Coefficient</th>
                            <th style="width:150px">Heures / semaine</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% set currentCycle = null %}
                        {% for mnForm in form.matiereNiveaux %}
                            {% set niveau = mnForm.vars.data.niveau %}
                            {% set cycleName = niveau.cycle.nom %}
                            <tr>
                                <td class="text-muted small">
                                    {% if cycleName != currentCycle %}
                                        {{ cycleName }}
                                        {% set currentCycle = cycleName %}
                                    {% endif %}
                                </td>
                                <td>{{ niveau }}</td>
                                <td>{{ form_widget(mnForm.coefficient) }}</td>
                                <td>{{ form_widget(mnForm.heuresParSemaine) }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Enregistrer
                    </button>
                    <a href="{{ path('admin_matiere_index') }}" class="btn btn-outline-secondary">Annuler</a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
