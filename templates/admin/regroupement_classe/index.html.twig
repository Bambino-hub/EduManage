{% extends 'admin/layout.html.twig' %}
{% import 'admin/macros.html.twig' as ui %}

{% block title %}Regroupements de classes — EduManage{% endblock %}
{% block page_title %}Regroupements de classes{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h4 mb-1">Regroupements de classes</h1>
        <p class="text-muted mb-0" style="font-size:.85rem">
            Classes fusionnées pour certaines matières (mêmes créneaux imposés) — ex. une petite classe
            réunie avec une autre pour les matières à volume horaire identique.
        </p>
    </div>
    <a href="{{ path('admin_regroupement_classe_new') }}" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>Nouveau regroupement
    </a>
</div>

<div class="admin-card">
    <div class="admin-card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nom</th>
                    <th>Classes</th>
                    <th>Matières</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for r in regroupements %}
                    <tr>
                        <td class="fw-semibold">{{ r.nom }}</td>
                        <td>
                            {% for c in r.classes %}
                                <span class="badge text-bg-light border">{{ c.nom }}</span>
                            {% endfor %}
                        </td>
                        <td>
                            {% for m in r.matieres %}
                                <span class="badge text-bg-light border">{{ m.code }}</span>
                            {% endfor %}
                        </td>
                        <td>
                            {{ ui.actions(
                                path('admin_regroupement_classe_edit', {id: r.id}),
                                path('admin_regroupement_classe_delete', {id: r.id}),
                                r.id,
                                'Supprimer ce regroupement ?'
                            ) }}
                        </td>
                    </tr>
                {% else %}
                    {{ ui.empty_row(4, 'Aucun regroupement de classes défini.') }}
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
