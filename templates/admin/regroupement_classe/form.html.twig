{% extends 'admin/layout.html.twig' %}

{% block title %}{{ regroupement.id ? 'Modifier' : 'Nouveau' }} regroupement — EduManage{% endblock %}
{% block page_title %}{{ regroupement.id ? 'Modifier' : 'Nouveau' }} regroupement de classes{% endblock %}

{% block admin_content %}
<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="admin-card">
            <div class="admin-card-header">
                <h2 class="admin-card-title">
                    <i class="bi bi-people-fill me-2 text-college-purple"></i>
                    {{ regroupement.id ? regroupement.nom : 'Nouveau regroupement' }}
                </h2>
                <a href="{{ path('admin_regroupement_classe_index') }}" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Retour
                </a>
            </div>
            <div class="admin-card-body">
                {{ form_start(form) }}
                {{ form_errors(form) }}
                <div class="row g-3">
                    <div class="col-12">{{ form_row(form.nom) }}</div>
                    <div class="col-md-6">{{ form_row(form.classes) }}</div>
                    <div class="col-md-6">{{ form_row(form.matieres) }}</div>
                </div>
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Enregistrer
                    </button>
                    <a href="{{ path('admin_regroupement_classe_index') }}" class="btn btn-outline-secondary">Annuler</a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
