{% extends 'admin/layout.html.twig' %}

{% block title %}Examens — EduManage{% endblock %}
{% block page_title %}Examens{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
    <h1 class="h4 mb-0">Programme des examens</h1>
    <div class="d-flex gap-2">
        <form method="post" action="{{ path('admin_examen_publier_tout') }}"
              onsubmit="return confirm('Publier tous les examens (collège et lycée) sur le site public ?');">
            <input type="hidden" name="_token" value="{{ csrf_token('publier_tout_examens') }}">
            <button type="submit" class="btn btn-success btn-sm">
                <i class="bi bi-globe2 me-1"></i>Publier les examens
            </button>
        </form>
        <form method="post" action="{{ path('admin_examen_depublier_tout') }}"
              onsubmit="return confirm('Retirer tous les examens (collège et lycée) du site public ?');">
            <input type="hidden" name="_token" value="{{ csrf_token('depublier_tout_examens') }}">
            <button type="submit" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-eye-slash me-1"></i>Annuler la publication
            </button>
        </form>
    </div>
</div>

<div class="row g-4">
    {% for cycle in cycles %}
        <div class="col-md-6">
            <div class="admin-card h-100">
                <div class="admin-card-body d-flex flex-column">
                    <h2 class="h5 mb-1">
                        <i class="bi bi-journal-text me-2 text-college-purple"></i>{{ cycle.nom }}
                    </h2>
                    <p class="text-muted small mb-3">{{ cycle.type.label() }} — {{ cycle.niveaux|length }} niveau(x)</p>
                    <a href="{{ path('admin_examen_tableau', {cycle: cycle.id}) }}" class="btn btn-primary btn-sm mt-auto align-self-start">
                        <i class="bi bi-table me-1"></i>Voir le programme des devoirs
                    </a>
                </div>
            </div>
        </div>
    {% else %}
        <div class="col-12">
            <div class="admin-card">
                <div class="admin-card-body text-center text-muted py-5">Aucun cycle configuré.</div>
            </div>
        </div>
    {% endfor %}
</div>
{% endblock %}
