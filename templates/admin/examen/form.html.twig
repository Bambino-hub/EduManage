{% extends 'admin/layout.html.twig' %}

{% block title %}{{ examen.id ? 'Modifier' : 'Nouvel' }} examen — EduManage{% endblock %}
{% block page_title %}{{ examen.id ? 'Modifier' : 'Nouvel' }} examen{% endblock %}

{% block admin_content %}
<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="admin-card">
            <div class="admin-card-header">
                <h2 class="admin-card-title">
                    <i class="bi bi-file-earmark-ruled-fill me-2 text-college-purple"></i>
                    {{ examen.id ? 'Modifier l\'examen' : 'Nouvel examen' }} — {{ cycle.nom }}
                </h2>
                <a href="{{ path('admin_examen_tableau', {cycle: cycle.id}) }}" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Retour
                </a>
            </div>
            <div class="admin-card-body">
                {{ form_start(form) }}
                {{ form_errors(form) }}

                <div class="row g-3">
                    <div class="col-6">{{ form_row(form.matiere) }}</div>
                    <div class="col-6">{{ form_row(form.nombreSurveillantsParClasse) }}</div>
                </div>
                <div class="row g-3">
                    <div class="col-4">{{ form_row(form.date) }}</div>
                    <div class="col-4">{{ form_row(form.heureDebut) }}</div>
                    <div class="col-4">{{ form_row(form.heureFin) }}</div>
                </div>

                <div data-controller="exam-level-toggle" class="mt-3">
                    {{ form_errors(form.niveaux) }}
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <label class="fw-semibold mb-0">{{ form_label(form.niveaux) }}</label>
                        <label class="form-check form-switch mb-0 d-flex align-items-center gap-2">
                            <input class="form-check-input" type="checkbox"
                                   data-exam-level-toggle-target="toggle"
                                   data-action="change->exam-level-toggle#toggleAll">
                            <span class="small text-muted">Tout sélectionner</span>
                        </label>
                    </div>
                    <p class="text-muted small">{{ form.niveaux.vars.help }}</p>
                    <div class="row g-2">
                        {% for child in form.niveaux %}
                            <div class="col-6 col-md-4">
                                <div class="form-check">
                                    {{ form_widget(child, {
                                        attr: {
                                            'data-exam-level-toggle-target': 'level',
                                            'data-action': 'change->exam-level-toggle#onLevelChange',
                                        },
                                    }) }}
                                    {{ form_label(child, null, {label_attr: {class: 'form-check-label'}}) }}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Enregistrer
                    </button>
                    <a href="{{ path('admin_examen_tableau', {cycle: cycle.id}) }}" class="btn btn-outline-secondary">Annuler</a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
