{% extends 'admin/layout.html.twig' %}

{% block title %}Importer une fiche de notes — EduManage{% endblock %}
{% block page_title %}Importer une fiche de notes{% endblock %}

{% block admin_content %}
<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="admin-card">
            <div class="admin-card-header">
                <h2 class="admin-card-title">
                    <i class="bi bi-camera-fill me-2 text-college-purple"></i>
                    {{ attribution.classe.nom }} — {{ attribution.matiere.nom }}
                </h2>
                <a href="{{ path('admin_notes_attribution', {id: attribution.id}) }}" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Retour
                </a>
            </div>
            <div class="admin-card-body">
                <div class="alert alert-info d-flex gap-2 mb-4" style="font-size:.85rem">
                    <i class="bi bi-info-circle-fill flex-shrink-0 mt-1"></i>
                    <div>
                        Scannez ou photographiez la fiche de notes remplie à la main (colonnes
                        <strong>Moy Interro / Moy Devoir / Compos</strong>). La lecture automatique propose un
                        rapprochement avec les élèves de la classe — rien n'est enregistré tant que vous n'avez
                        pas vérifié et confirmé l'aperçu à l'étape suivante.
                    </div>
                </div>

                {{ form_start(form, {action: path('admin_note_import_preview', {id: attribution.id}), method: 'POST'}) }}
                {{ form_errors(form) }}
                {{ form_row(form.fichier) }}
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-upload me-1"></i>Analyser la fiche
                    </button>
                    <a href="{{ path('admin_notes_attribution', {id: attribution.id}) }}" class="btn btn-outline-secondary">Annuler</a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
