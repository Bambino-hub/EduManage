{% extends 'admin/layout.html.twig' %}

{% block title %}{{ annee.id ? 'Modifier' : 'Nouvelle' }} année — EduManage{% endblock %}
{% block page_title %}{{ annee.id ? 'Modifier' : 'Nouvelle' }} année scolaire{% endblock %}

{% block admin_content %}
<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="admin-card">
            <div class="admin-card-header">
                <h2 class="admin-card-title">
                    <i class="bi bi-calendar-range me-2 text-college-purple"></i>
                    {{ annee.id ? 'Modifier ' ~ annee.libelle : 'Nouvelle année scolaire' }}
                </h2>
                <a href="{{ path('admin_annee_index') }}" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Retour
                </a>
            </div>
            <div class="admin-card-body">
                {{ form_start(form) }}
                {{ form_errors(form) }}
                <div class="row g-3">
                    <div class="col-12">{{ form_row(form.libelle) }}</div>
                    <div class="col-6">{{ form_row(form.dateDebut) }}</div>
                    <div class="col-6">{{ form_row(form.dateFin) }}</div>
                    <div class="col-12">{{ form_row(form.active) }}</div>
                    <div class="col-4">{{ form_row(form.poidsInterrogation) }}</div>
                    <div class="col-4">{{ form_row(form.poidsDevoirs) }}</div>
                    <div class="col-4">{{ form_row(form.poidsComposition) }}</div>
                </div>
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Enregistrer
                    </button>
                    <a href="{{ path('admin_annee_index') }}" class="btn btn-outline-secondary">Annuler</a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
