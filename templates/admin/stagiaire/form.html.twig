{% extends 'admin/layout.html.twig' %}

{% block title %}{{ stagiaire.id ? 'Modifier' : 'Ajouter' }} un stagiaire — EduManage{% endblock %}
{% block page_title %}{{ stagiaire.id ? 'Modifier' : 'Ajouter' }} un stagiaire{% endblock %}

{% block admin_content %}
<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="admin-card">
            <div class="admin-card-header">
                <h2 class="admin-card-title">
                    <i class="bi bi-person-workspace me-2 text-college-purple"></i>
                    {{ stagiaire.id ? stagiaire.nomComplet : 'Nouveau stagiaire' }}
                </h2>
                <a href="{{ path('admin_stagiaire_index') }}" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Retour
                </a>
            </div>
            <div class="admin-card-body">
                {{ form_start(form) }}
                {{ form_errors(form) }}
                <div class="row g-3">
                    <div class="col-7">{{ form_row(form.nom) }}</div>
                    <div class="col-5">{{ form_row(form.prenom) }}</div>
                    <div class="col-4">{{ form_row(form.sexe) }}</div>
                    <div class="col-8">{{ form_row(form.telephone) }}</div>
                    <div class="col-6">{{ form_row(form.cycle) }}</div>
                    <div class="col-6">{{ form_row(form.specialite) }}</div>
                    <div class="col-6">{{ form_row(form.tuteur) }}</div>
                    <div class="col-3">{{ form_row(form.dateDebutStage) }}</div>
                    <div class="col-3">{{ form_row(form.dateFinStage) }}</div>
                </div>
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Enregistrer
                    </button>
                    <a href="{{ path('admin_stagiaire_index') }}" class="btn btn-outline-secondary">Annuler</a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
