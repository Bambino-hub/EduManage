{% extends 'admin/layout.html.twig' %}

{% block title %}{{ actualite.id ? 'Modifier' : 'Nouvelle' }} actualité — EduManage{% endblock %}
{% block page_title %}{{ actualite.id ? 'Modifier' : 'Nouvelle' }} actualité{% endblock %}

{% block admin_content %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="admin-card">
            <div class="admin-card-header">
                <h2 class="admin-card-title">
                    <i class="bi bi-megaphone-fill me-2 text-college-purple"></i>
                    {{ actualite.id ? 'Modifier ' ~ actualite.titre : 'Nouvelle actualité' }}
                </h2>
                <a href="{{ path('admin_actualite_index') }}" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Retour
                </a>
            </div>
            <div class="admin-card-body">
                {{ form_start(form, {attr: {enctype: 'multipart/form-data'}}) }}
                {{ form_errors(form) }}

                <div class="row g-3 mb-3">
                    <div class="col-12">{{ form_row(form.titre) }}</div>
                    <div class="col-12">{{ form_row(form.contenu) }}</div>
                    <div class="col-12 col-sm-6">{{ form_row(form.datePublication) }}</div>
                    <div class="col-12 col-sm-6">{{ form_row(form.cycleConcerne) }}</div>
                </div>

                {% if actualite.image %}
                    <div class="mb-3">
                        <span class="form-label small fw-semibold d-block">Image actuelle</span>
                        <img src="{{ asset('uploads/actualites/' ~ actualite.image) }}" alt=""
                             class="rounded border" style="max-width:200px;max-height:140px;object-fit:cover">
                    </div>
                {% endif %}

                <div class="row g-3 mb-4">
                    <div class="col-12">{{ form_row(form.image) }}</div>
                    <div class="col-12">{{ form_row(form.publie) }}</div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>Enregistrer
                    </button>
                    <a href="{{ path('admin_actualite_index') }}" class="btn btn-outline-secondary">Annuler</a>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
