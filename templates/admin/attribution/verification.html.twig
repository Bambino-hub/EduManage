{% extends 'admin/layout.html.twig' %}

{% block title %}Vérification des attributions — EduManage{% endblock %}
{% block page_title %}Vérification des attributions{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h4 mb-1">Vérification des attributions</h1>
        <p class="text-muted mb-0" style="font-size:.85rem">
            Pour chaque niveau, repère les classes qui n'ont pas encore d'enseignant dans une matière enseignée.
        </p>
    </div>
    <a href="{{ path('admin_attribution_index') }}" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Retour aux attributions
    </a>
</div>

{% if annee is null %}
    <div class="admin-card">
        <div class="admin-card-body text-center text-muted py-5">
            <i class="bi bi-calendar-x display-6 d-block mb-2"></i>
            Aucune année scolaire active. Activez une année scolaire pour lancer la vérification.
        </div>
    </div>
{% elseif rapport.niveaux is empty %}
    <div class="admin-card">
        <div class="admin-card-body text-center text-muted py-5">
            <i class="bi bi-inbox display-6 d-block mb-2"></i>
            Aucune classe pour l'année {{ annee.libelle }}.
        </div>
    </div>
{% else %}
    {% if rapport.estComplet %}
        <div class="alert alert-success d-flex align-items-center gap-2">
            <i class="bi bi-check-circle-fill"></i>
            <div>Toutes les classes ont un enseignant affecté dans chaque matière enseignée pour l'année {{ annee.libelle }}.</div>
        </div>
    {% else %}
        <div class="alert alert-warning d-flex align-items-center gap-2">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <div>
                {{ rapport.nombreManquants }} case{{ rapport.nombreManquants > 1 ? 's' : '' }} classe/matière sans enseignant
                pour l'année {{ annee.libelle }} — le détail est signalé en rouge ci-dessous.
            </div>
        </div>
    {% endif %}

    {% for niveauCompletude in rapport.niveaux %}
        <div class="admin-card mb-4">
            <div class="admin-card-header">
                <h2 class="admin-card-title mb-0">{{ niveauCompletude.niveau.nomComplet }}</h2>
                {% if niveauCompletude.matieres is empty %}
                    <span class="badge bg-secondary">Aucune matière configurée</span>
                {% elseif niveauCompletude.estComplet %}
                    <span class="badge bg-success"><i class="bi bi-check-lg"></i> Complet</span>
                {% else %}
                    <span class="badge bg-danger">
                        {{ niveauCompletude.nombreManquants }} manquant{{ niveauCompletude.nombreManquants > 1 ? 's' : '' }}
                    </span>
                {% endif %}
            </div>

            {% if niveauCompletude.classesSansOption is not empty %}
                <div class="admin-card-body py-2 border-bottom bg-warning-subtle">
                    {% for cso in niveauCompletude.classesSansOption %}
                        <div class="small text-warning-emphasis">
                            <i class="bi bi-question-diamond-fill me-1"></i>
                            <strong>{{ cso.classe.nom }}</strong> n'a aucune matière choisie pour le groupe
                            « {{ cso.groupe.label }} » — à configurer sur la fiche de la classe.
                        </div>
                    {% endfor %}
                </div>
            {% endif %}

            {% if niveauCompletude.matieres is not empty %}
                <div class="admin-card-body p-0" style="overflow-x:auto">
                    <table class="table table-bordered align-middle mb-0 text-center" style="font-size:.8rem">
                        <thead class="table-light">
                            <tr>
                                <th class="text-start" style="min-width:150px">Matière</th>
                                {% for classe in niveauCompletude.classes %}
                                    <th style="min-width:120px">{{ classe.nom }}</th>
                                {% endfor %}
                            </tr>
                        </thead>
                        <tbody>
                            {% for matiereCompletude in niveauCompletude.matieres %}
                                <tr>
                                    <td class="text-start">
                                        <span class="d-inline-flex align-items-center gap-1">
                                            <span class="rounded-circle border d-inline-block"
                                                  style="width:10px;height:10px;background:{{ matiereCompletude.matiere.couleur }}"></span>
                                            {{ matiereCompletude.matiere.nom }}
                                        </span>
                                    </td>
                                    {% for classe in niveauCompletude.classes %}
                                        {% if not matiereCompletude.concerneeParClasseId[classe.id] %}
                                            <td class="text-muted">·</td>
                                        {% else %}
                                            {% set attribution = matiereCompletude.attributionsParClasseId[classe.id] %}
                                            {% if attribution %}
                                                <td class="text-success-emphasis bg-success-subtle">
                                                    <i class="bi bi-check-lg"></i> {{ attribution.enseignant.nomComplet }}
                                                </td>
                                            {% else %}
                                                <td class="text-danger-emphasis bg-danger-subtle fw-semibold">
                                                    <i class="bi bi-x-lg"></i> manquant
                                                </td>
                                            {% endif %}
                                        {% endif %}
                                    {% endfor %}
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    {% endfor %}
{% endif %}
{% endblock %}
