{% extends 'admin/layout.html.twig' %}
{% import 'admin/macros.html.twig' as ui %}

{% block title %}Classes — EduManage{% endblock %}
{% block page_title %}Classes{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h4 mb-0">Classes</h1>
    <a href="{{ path('admin_classe_new') }}" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>Nouvelle classe
    </a>
</div>

<div class="admin-card">
    <div class="admin-card-body p-0">
        <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 table-stack">
            <thead class="table-light">
                <tr>
                    <th>Classe</th>
                    <th>Niveau</th>
                    <th>Cycle</th>
                    <th>Année scolaire</th>
                    <th>Effectif max</th>
                    <th>Statut</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for classe in classes %}
                <tr>
                    <td class="fw-semibold td-title">{{ classe.nom }}</td>
                    <td data-label="Niveau">{{ classe.niveau.nomComplet }}</td>
                    <td data-label="Cycle"><span class="badge bg-secondary">{{ classe.niveau.cycle.nom }}</span></td>
                    <td data-label="Année scolaire">{{ classe.anneeScolaire.libelle }}</td>
                    <td class="text-muted" data-label="Effectif max">{{ classe.effectifMax }} élèves</td>
                    <td data-label="Statut">
                        {% if classe.active %}
                            <span class="badge bg-success">Active</span>
                        {% else %}
                            <span class="badge bg-secondary">Inactive</span>
                        {% endif %}
                    </td>
                    <td>
                        {{ ui.actions(
                            path('admin_classe_edit', {id: classe.id}),
                            path('admin_classe_delete', {id: classe.id}),
                            classe.id,
                            'Supprimer la classe ' ~ classe.nom ~ ' ?',
                            path('admin_eleve_par_classe', {classe: classe.id})
                        ) }}
                    </td>
                </tr>
                {% else %}
                    {{ ui.empty_row(7, 'Aucune classe. Créez d\'abord les niveaux et l\'année scolaire.') }}
                {% endfor %}
            </tbody>
        </table>
        </div>
    </div>
</div>
{% endblock %}
