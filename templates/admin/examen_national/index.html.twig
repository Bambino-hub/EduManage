{% extends 'admin/layout.html.twig' %}
{% import 'admin/macros.html.twig' as ui %}

{% block title %}Examens nationaux — EduManage{% endblock %}
{% block page_title %}Examens nationaux{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h4 mb-1">Statistiques d'examens nationaux</h1>
        <p class="text-muted mb-0" style="font-size:.85rem">BEPC, BAC 1ère et 2ème partie — importées depuis les relevés officiels scannés.</p>
    </div>
    <a href="{{ path('admin_releve_national_import_new') }}" class="btn btn-primary">
        <i class="bi bi-file-earmark-arrow-up-fill me-1"></i>Importer un relevé
    </a>
</div>

<div class="admin-card">
    <div class="admin-card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 table-stack">
                <thead class="table-light">
                    <tr>
                        <th>Examen</th>
                        <th>Série</th>
                        <th>Année</th>
                        <th>Centre</th>
                        <th class="text-center">Candidats</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for session in sessions %}
                        <tr>
                            <td class="fw-semibold td-title" data-label="Examen">{{ session.type.label }}</td>
                            <td data-label="Série">{{ session.serie }}{{ session.libelleSerie ? ' — ' ~ session.libelleSerie }}</td>
                            <td data-label="Année">{{ session.anneeSession ?? '—' }}</td>
                            <td data-label="Centre">{{ session.centreExamen ?? '—' }}</td>
                            <td class="text-center" data-label="Candidats">{{ session.candidats|length }}</td>
                            <td class="text-end">
                                <a href="{{ path('admin_releve_national_show', {id: session.id}) }}" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-bar-chart-line me-1"></i>Statistiques
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        {{ ui.empty_row(6, 'Aucun relevé importé pour l\'instant.') }}
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
